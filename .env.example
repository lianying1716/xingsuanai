# 复制本文件为 .env 并填入实际值
WECHAT_ARTICLE_AUTH_KEY=your_auth_key_here
WECHAT_ARTICLE_PROXY_URLS=https://your-worker.workers.dev
WECHAT_ARTICLE_PROXY_AUTH=your_proxy_password

# 抖小云 — Douyin 视频下载管理（dysync.net）
DYSYNC_URL=http://192.168.2.4:10101
DYSYNC_USERNAME=your_dysync_username
DYSYNC_PASSWORD=your_dysync_password
