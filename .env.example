# 复制本文件为 .env 并填入实际值(真实密钥绝不提交,.env 已被 .gitignore 忽略)

# ── GitHub 内容来源 / 技能抓取管道(github_import / group_mine / cocoloop_mine / backfill 等) ──
GITHUB_USER=your_github_username
GITHUB_TOKEN=ghp_your_github_personal_access_token   # 只需 public repo 读权限

# 大白话加工模型(自家 API 中转,OpenAI 兼容)
NEXAI_RELAY_BASE_URL=https://api.xsai5.xyz/v1
NEXAI_RELAY_API_KEY=xsai_sk_your_relay_key
NEXAI_RELAY_MODEL=gpt-5.4-mini

# 写入星算客户端(插件中心 / 内容中心 / 痛点包)的运营网关 token
# 需具备 scope: desktop.plugins.read/write + content.trending.read/write
OPERATOR_BASE_URL=https://xsai5.xyz
OPERATOR_TOKEN=xsai_operator_your_operator_token

# ── 公众号采集(wechat-article skill) ──
WECHAT_ARTICLE_AUTH_KEY=your_auth_key_here
WECHAT_ARTICLE_PROXY_URLS=https://your-worker.workers.dev
WECHAT_ARTICLE_PROXY_AUTH=your_proxy_password

# ── 抖小云 Douyin 视频下载管理(dysync.net) ──
DYSYNC_URL=http://192.168.2.4:10101
DYSYNC_USERNAME=your_dysync_username
DYSYNC_PASSWORD=your_dysync_password
