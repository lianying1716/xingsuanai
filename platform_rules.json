{
  "_说明": "内容作战·独立审查关卡的机器可读规则。供审查 agent / content_review.py 调用：扫红线词 + 按平台判 CTA 合规 + 质量打分。规则每季度用搜索技能复查更新。",
  "_最近复查": "2026-06-06",

  "quality_rubric": {
    "threshold": 80,
    "dimensions": [
      { "key": "选题价值", "weight": 25, "check": "目标群体真需要还是自嗨；是否命中真痛点", "reject_to": "选题" },
      { "key": "钩子开头", "weight": 20, "check": "3秒能否勾住(B站/小红书尤其)", "reject_to": "派生改写" },
      { "key": "可读性", "weight": 15, "check": "小白能否看懂；术语是否解释(受众定律)", "reject_to": "装配" },
      { "key": "转化设计", "weight": 15, "check": "CTA是否自然有力、路径清晰且合规", "reject_to": "派生改写" },
      { "key": "配图质量", "weight": 15, "check": "封面/图文是否到位专业不糊", "reject_to": "配图" },
      { "key": "差异化", "weight": 10, "check": "比平台已有内容有无新价值", "reject_to": "选题" }
    ],
    "output_requires": ["质量分", "各维度扣分理由", "改进建议"]
  },

  "global_redlines": {
    "_命中任一即打回": true,
    "政策高压线_绝不可提": ["翻墙", "VPN", "科学上网", "梯子", "机场节点", "外卡", "信用卡绕过", "fq", "🪜"],
    "替代表达": "只说『国内直连 / 稳定连接 / 国内网络可直接用』，绝不暗示绕过访问限制",
    "绝对化极限词_广告法第九条": ["最", "第一", "唯一", "顶级", "顶尖", "国家级", "最高级", "最佳", "最好", "100%", "官方认证", "首选", "领先", "无敌", "永久", "终身"],
    "绝对化替代话术": { "最好/最佳": "表现出色/口碑不错", "第一/唯一": "热门/广受好评", "100%/官方": "通过XX验证/实测可用" },
    "其它禁词": ["官方", "破解", "盗版", "免费白嫖", "黑卡"],
    "措辞谨慎_API中转": "对外说『国内可直接用的 API、按量计费』，少用『中转/代理』字眼"
  },

  "platforms": {
    "小红书": {
      "external_link_policy": "极严·禁外部导流",
      "risk_keywords": ["微信", "vx", "v信", "薇", "卫星", "加我", "私信领", "二维码", "扫码", "链接", "公众号", "QQ", "电话"],
      "cta_allowed": "仅极干货+自然露出品牌词『星算助手』让用户自行搜索；禁任何联系方式/链接/码及其变体",
      "ai_label_required": true,
      "extra_redlines": ["内容重复度过高/自我抄袭→降权", "未标注AI内容", "虚假数据"],
      "prefers": "真实第一人称体验、系统干货、清晰配图"
    },
    "公众号": {
      "external_link_policy": "严·禁诱导",
      "risk_keywords": ["分享到朋友圈", "集赞", "分享后才能", "诱导关注", "转发领", "点赞解锁"],
      "cta_allowed": "文末软引导 / 菜单栏 / 自动回复给资源，但不得诱导分享或关注",
      "ai_label_required": false,
      "extra_redlines": ["诱导分享", "诱导关注", "利益诱导传播外链"],
      "prefers": "深度长文、干货"
    },
    "知乎": {
      "external_link_policy": "中·可带链接但禁利益诱导点击",
      "risk_keywords": ["点击卡片", "截图私信", "私信领取", "扫码加群"],
      "cta_allowed": "原生融入、干货回答末尾自然带产品；半人半AI需人工校验并标注来源",
      "ai_label_required": true,
      "extra_redlines": ["绝对化用语", "夸大宣传", "虚假承诺", "机械AI文案"],
      "prefers": "专业性、知识性、有数据有逻辑"
    },
    "掘金": {
      "external_link_policy": "中·禁纯硬广",
      "risk_keywords": ["纯广告", "推广海报"],
      "cta_allowed": "技术帖中自然提及工具与使用方式",
      "ai_label_required": false,
      "extra_redlines": ["低质搬运", "纯硬广"],
      "prefers": "真实技术实操、可复现、带代码"
    },
    "B站": {
      "external_link_policy": "低·简介/视频可带链接",
      "risk_keywords": ["标题党"],
      "cta_allowed": "口播 + 简介引导下载并填渠道码",
      "ai_label_required": false,
      "extra_redlines": ["频繁改稿重传(投稿异常→隐形限流)", "标题党过头", "转载当自制", "低创"],
      "prefers": "录屏实操、不露脸、系列化"
    },
    "Linux.do/V2EX": {
      "external_link_policy": "低但社区敏感·绝不硬广",
      "risk_keywords": ["硬广", "纯推广帖"],
      "cta_allowed": "真·干货答疑中自然带出星算助手，解决真实问题",
      "ai_label_required": false,
      "extra_redlines": ["硬广(会被踩/封)", "灌水"],
      "prefers": "真实解决开发者问题、技术深度"
    }
  }
}
